# --- Vercel (set in Project → Settings → Environment Variables) ---
# Production + Preview: public canonical host (no trailing slash).
# Set in Vercel → Production (and Preview if you want preview canonicals on www).
# Sitemap/robots on production use this when set; if omitted, production falls back to siteConfig.url
# (never *.vercel.app) so Google Search Console stays valid — see src/config/site.ts getSiteUrl().
NEXT_PUBLIC_SITE_URL=https://www.thelakesvegas.com

# Injected automatically on Vercel builds — do not commit secrets; document only:
# VERCEL=1, VERCEL_ENV=production|preview|development, VERCEL_URL, VERCEL_REGION, etc.
# https://vercel.com/docs/projects/environment-variables/system-environment-variables

# Google Search Console → Settings → Ownership verification → HTML tag
# Paste only the string inside content="..." (then redeploy / Production so layout.tsx picks it up).
# https://search.google.com/search-console
GOOGLE_SITE_VERIFICATION=

# --- Optional integrations (site builds without these) ---
# OPENROUTER_API_KEY=          # AI chat widget (/api/chat)
# ANTHROPIC_API_KEY=           # Claude route (/api/claude/chat)
# UPSTASH_REDIS_REST_URL=      # Rate limits
# UPSTASH_REDIS_REST_TOKEN=
# FUB_API_KEY=                 # Follow Up Boss (leads + webhooks)
